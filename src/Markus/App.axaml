<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Markus.App"
             xmlns:services="using:Markus.Services"
             Name="Markus"
             RequestedThemeVariant="Default">

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="About Markus"
                      Command="{x:Static services:AppCommands.About}"/>
      <NativeMenuItem Header="Check for Updates…"
                      Command="{x:Static services:AppCommands.CheckForUpdates}"/>
      <NativeMenuItemSeparator/>
      <NativeMenuItem Header="Preferences…" Gesture="Cmd+,"
                      Command="{x:Static services:AppCommands.Preferences}"/>
      <NativeMenuItemSeparator/>
      <NativeMenuItem Header="Quit Markus" Gesture="Cmd+Q"
                      Command="{x:Static services:AppCommands.Quit}"/>
    </NativeMenu>
  </NativeMenu.Menu>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>

        <!-- ============ Light ============ -->
        <ResourceDictionary x:Key="Light">
          <!-- Atmosphere — warm cream with a single sienna ember in the
               top-right corner. The previous rainbow mesh fought the
               content; restraint here lets the document carry the eye. -->
          <SolidColorBrush x:Key="AppBackground" Color="#F8F4EA"/>
          <Color x:Key="MeshAColor">#F4ECD8</Color>
          <Color x:Key="MeshBColor">#E6DBC4</Color>
          <Color x:Key="MeshCColor">#E5B299</Color>

          <!-- Glass -->
          <SolidColorBrush x:Key="GlassBg" Color="#C0FFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#18000000"/>
          <SolidColorBrush x:Key="GlassDivider" Color="#0C000000"/>
          <SolidColorBrush x:Key="GlassHover" Color="#18000000"/>
          <SolidColorBrush x:Key="GlassPressed" Color="#28000000"/>

          <!-- Brand accent — a fixed sienna so the SHELL has a consistent
               Markus identity regardless of the OS accent the user has
               picked (blue, red, multicolor, …). The PREVIEW is unaffected
               because it pulls from MarkdownTheme.Accent. The Settings
               window keeps its own scoped Photos.app palette per its
               existing in-file comment. -->
          <SolidColorBrush x:Key="Accent" Color="#B23A2E"/>
          <SolidColorBrush x:Key="AccentSoft" Color="#B23A2E" Opacity="0.12"/>
          <Color x:Key="AccentColor">#B23A2E</Color>

          <!-- Text -->
          <SolidColorBrush x:Key="TextHigh" Color="#1A1A1F"/>
          <SolidColorBrush x:Key="TextMedium" Color="#3C3C44"/>
          <SolidColorBrush x:Key="TextLow" Color="#6E6E7A"/>

          <!-- Content surface -->
          <SolidColorBrush x:Key="ContentBg" Color="#88FFFFFF"/>
          <SolidColorBrush x:Key="ContentInk" Color="#1A1A1F"/>

          <!-- Translucent tint over the system vibrancy so chrome reads as
               frosted glass, not as bare blur. -->
          <SolidColorBrush x:Key="WindowTint" Color="#66FFFFFF"/>

          <!-- Opaque-ish surface for floating popovers (search overlay, etc.). -->
          <SolidColorBrush x:Key="OverlayBg" Color="#F5F6F8F9"/>
          <SolidColorBrush x:Key="OverlayBorder" Color="#22000000"/>

          <!-- Liquid Glass platters -->
          <SolidColorBrush x:Key="PlatterBg" Color="#5CFFFFFF"/>
          <SolidColorBrush x:Key="PlatterHoverBg" Color="#80FFFFFF"/>
          <SolidColorBrush x:Key="PlatterPressedBg" Color="#A6FFFFFF"/>
          <SolidColorBrush x:Key="PlatterCheckedBg" Color="#80FFFFFF"/>
          <LinearGradientBrush x:Key="PlatterBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#88FFFFFF" Offset="0"/>
            <GradientStop Color="#0C000000" Offset="1"/>
          </LinearGradientBrush>
          <BoxShadows x:Key="ToolbarShadow">0 1 2 0 #0A000000</BoxShadows>
          <SolidColorBrush x:Key="ToolbarSurface" Color="#00FFFFFF"/>
          <SolidColorBrush x:Key="PlatterIcon" Color="#8A000000"/>
          <SolidColorBrush x:Key="PlatterLabel" Color="#1A1A1F"/>
        </ResourceDictionary>

        <!-- ============ Dark ============ -->
        <ResourceDictionary x:Key="Dark">
          <!-- Atmosphere — warm charcoal with a single warmer sienna ember
               in the top-right corner. Mirrors the Light dictionary's
               restraint: one corner of brand warmth against a quiet field. -->
          <SolidColorBrush x:Key="AppBackground" Color="#16110E"/>
          <Color x:Key="MeshAColor">#2A211A</Color>
          <Color x:Key="MeshBColor">#1F1814</Color>
          <Color x:Key="MeshCColor">#5A2E20</Color>

          <!-- Glass -->
          <SolidColorBrush x:Key="GlassBg" Color="#18FFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#22FFFFFF"/>
          <SolidColorBrush x:Key="GlassDivider" Color="#14FFFFFF"/>
          <SolidColorBrush x:Key="GlassHover" Color="#22FFFFFF"/>
          <SolidColorBrush x:Key="GlassPressed" Color="#33FFFFFF"/>

          <!-- Same brand accent, warmed for legibility on dark surfaces. -->
          <SolidColorBrush x:Key="Accent" Color="#E28268"/>
          <SolidColorBrush x:Key="AccentSoft" Color="#E28268" Opacity="0.16"/>
          <Color x:Key="AccentColor">#E28268</Color>

          <!-- Text -->
          <SolidColorBrush x:Key="TextHigh" Color="#F0F0F4"/>
          <SolidColorBrush x:Key="TextMedium" Color="#A8A8B4"/>
          <SolidColorBrush x:Key="TextLow" Color="#70707E"/>

          <!-- Content surface -->
          <SolidColorBrush x:Key="ContentBg" Color="#0E0E18"/>
          <SolidColorBrush x:Key="ContentInk" Color="#F0F0F4"/>

          <!-- Translucent dark tint over the system vibrancy. -->
          <SolidColorBrush x:Key="WindowTint" Color="#80000000"/>

          <!-- Opaque-ish surface for floating popovers. -->
          <SolidColorBrush x:Key="OverlayBg" Color="#F5202028"/>
          <SolidColorBrush x:Key="OverlayBorder" Color="#2AFFFFFF"/>

          <!-- Liquid Glass platters, dark variant. -->
          <SolidColorBrush x:Key="PlatterBg" Color="#1CFFFFFF"/>
          <SolidColorBrush x:Key="PlatterHoverBg" Color="#2AFFFFFF"/>
          <SolidColorBrush x:Key="PlatterPressedBg" Color="#3DFFFFFF"/>
          <SolidColorBrush x:Key="PlatterCheckedBg" Color="#2AFFFFFF"/>
          <LinearGradientBrush x:Key="PlatterBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#40FFFFFF" Offset="0"/>
            <GradientStop Color="#18000000" Offset="1"/>
          </LinearGradientBrush>
          <BoxShadows x:Key="ToolbarShadow">0 1 2 0 #14FFFFFF</BoxShadows>
          <SolidColorBrush x:Key="ToolbarSurface" Color="#00FFFFFF"/>
          <SolidColorBrush x:Key="PlatterIcon" Color="#C2FFFFFF"/>
          <SolidColorBrush x:Key="PlatterLabel" Color="#F0F0F4"/>
        </ResourceDictionary>

      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>

    <!-- ============ Global typography (system fonts only) ============ -->
    <!-- A pure-system stack: SF on macOS, Segoe UI on Windows, ui-sans-serif
         everywhere else. No bundled custom families — the OS picks the most
         refined sans it owns, and the editorial feel comes from weight,
         tracking, and color rather than a distinctive face. -->
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="-apple-system,BlinkMacSystemFont,Segoe UI,ui-sans-serif,system-ui,sans-serif"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextHigh}"/>
    </Style>

    <!-- ============ Display: editorial restraint ============ -->
    <!-- A condensed stretch + light weight + negative tracking gives the
         "Markus" wordmark a deliberate, magazine-cover register without
         needing a display typeface. -->
    <Style Selector="TextBlock.display">
      <Setter Property="FontFamily" Value="-apple-system,BlinkMacSystemFont,Segoe UI,ui-sans-serif,system-ui,sans-serif"/>
      <Setter Property="FontWeight" Value="Light"/>
      <Setter Property="FontStretch" Value="Condensed"/>
      <Setter Property="FontSize" Value="38"/>
      <Setter Property="LetterSpacing" Value="-1.0"/>
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontFamily" Value="-apple-system,BlinkMacSystemFont,Segoe UI,ui-sans-serif,system-ui,sans-serif"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="LetterSpacing" Value="-0.3"/>
    </Style>

    <!-- Eyebrow labels — sparse caps, generous tracking, low-contrast. -->
    <Style Selector="TextBlock.section">
      <Setter Property="FontFamily" Value="-apple-system,BlinkMacSystemFont,Segoe UI,ui-sans-serif,system-ui,sans-serif"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="LetterSpacing" Value="2.4"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
    </Style>

    <!-- Compact meta info (status bar pills, captions). Mono for stable
         column widths so changing values do not shimmer the layout. -->
    <Style Selector="TextBlock.meta">
      <Setter Property="FontFamily" Value="Menlo,Consolas,ui-monospace,monospace"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
    </Style>

    <!-- A faint hairline used as visual punctuation between meta clusters. -->
    <Style Selector="Rectangle.hair">
      <Setter Property="Width" Value="1"/>
      <Setter Property="Height" Value="10"/>
      <Setter Property="Fill" Value="{DynamicResource GlassDivider}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Update-banner inline links: text-shaped buttons that read as
         editorial captions rather than CTAs. The Install variant
         carries the only color emphasis in this strip. -->
    <Style Selector="Button.updateAction">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMedium}"/>
    </Style>
    <Style Selector="Button.updateAction:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="Button.updatePrimary">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>

  </Application.Styles>
</Application>
