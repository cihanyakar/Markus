<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Markus.App"
             xmlns:local="using:Markus"
             xmlns:services="using:Markus.Services"
             RequestedThemeVariant="Default">

  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="About Markus"
                      Command="{x:Static services:AppCommands.About}"/>
      <NativeMenuItemSeparator/>
      <NativeMenuItem Header="Preferences…" Gesture="Cmd+,"
                      Command="{x:Static services:AppCommands.Preferences}"/>
      <NativeMenuItemSeparator/>
      <NativeMenuItem Header="Quit Markus" Gesture="Cmd+Q"
                      Command="{x:Static services:AppCommands.Quit}"/>
    </NativeMenu>
  </NativeMenu.Menu>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>

        <!-- ============ Light ============ -->
        <ResourceDictionary x:Key="Light">
          <!-- Atmosphere -->
          <SolidColorBrush x:Key="AppBackground" Color="#F5F2EE"/>
          <Color x:Key="MeshAColor">#FFB199</Color>
          <Color x:Key="MeshBColor">#A5B4FC</Color>
          <Color x:Key="MeshCColor">#B2F5EA</Color>

          <!-- Glass -->
          <SolidColorBrush x:Key="GlassBg" Color="#B8FFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#1F000000"/>
          <SolidColorBrush x:Key="GlassDivider" Color="#10000000"/>
          <SolidColorBrush x:Key="GlassHover" Color="#1F000000"/>
          <SolidColorBrush x:Key="GlassPressed" Color="#33000000"/>

          <!-- Accent -->
          <SolidColorBrush x:Key="Accent" Color="#FF2D55"/>
          <SolidColorBrush x:Key="AccentSoft" Color="#33FF2D55"/>
          <Color x:Key="AccentColor">#FF2D55</Color>

          <!-- Text -->
          <SolidColorBrush x:Key="TextHigh" Color="#1D1D1F"/>
          <SolidColorBrush x:Key="TextMedium" Color="#3A3A3C"/>
          <SolidColorBrush x:Key="TextLow" Color="#6E6E73"/>

          <!-- Content surface -->
          <SolidColorBrush x:Key="ContentBg" Color="#80FFFFFF"/>
          <SolidColorBrush x:Key="ContentInk" Color="#1D1D1F"/>

          <!-- Translucent tint over the system vibrancy so chrome reads as
               frosted glass, not as bare blur. -->
          <SolidColorBrush x:Key="WindowTint" Color="#59FFFFFF"/>

          <!-- Opaque-ish surface for floating popovers (search overlay, etc.). -->
          <SolidColorBrush x:Key="OverlayBg" Color="#F5F5F5F7"/>
          <SolidColorBrush x:Key="OverlayBorder" Color="#2E000000"/>

          <!-- Liquid Glass platters: tokens from rdev/liquid-glass-react (Tahoe).
               Alpha bumped to ~40/55/70/55% for legibility over Sidebar vibrancy. -->
          <SolidColorBrush x:Key="PlatterBg" Color="#66FFFFFF"/>
          <SolidColorBrush x:Key="PlatterHoverBg" Color="#8CFFFFFF"/>
          <SolidColorBrush x:Key="PlatterPressedBg" Color="#B3FFFFFF"/>
          <SolidColorBrush x:Key="PlatterCheckedBg" Color="#8CFFFFFF"/>
          <!-- Vertical edge gradient: bright top to faint dark bottom.
               Replaces inset BoxShadow which renders with pixelated edges in
               Avalonia 12. The BorderBrush + 1px BorderThickness gives a
               crisp glass rim at any corner radius. -->
          <LinearGradientBrush x:Key="PlatterBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#99FFFFFF" Offset="0"/>
            <GradientStop Color="#10000000" Offset="1"/>
          </LinearGradientBrush>
          <BoxShadows x:Key="ToolbarShadow">0 1 0 0 #14000000</BoxShadows>
          <SolidColorBrush x:Key="ToolbarSurface" Color="#00FFFFFF"/>
          <SolidColorBrush x:Key="PlatterIcon" Color="#D9000000"/>
          <SolidColorBrush x:Key="PlatterLabel" Color="#1D1D1F"/>
        </ResourceDictionary>

        <!-- ============ Dark ============ -->
        <ResourceDictionary x:Key="Dark">
          <!-- Atmosphere -->
          <SolidColorBrush x:Key="AppBackground" Color="#08080C"/>
          <Color x:Key="MeshAColor">#FF3D7F</Color>
          <Color x:Key="MeshBColor">#4F46E5</Color>
          <Color x:Key="MeshCColor">#06B6D4</Color>

          <!-- Glass -->
          <SolidColorBrush x:Key="GlassBg" Color="#1FFFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#33FFFFFF"/>
          <SolidColorBrush x:Key="GlassDivider" Color="#1FFFFFFF"/>
          <SolidColorBrush x:Key="GlassHover" Color="#2BFFFFFF"/>
          <SolidColorBrush x:Key="GlassPressed" Color="#3FFFFFFF"/>

          <!-- Accent -->
          <SolidColorBrush x:Key="Accent" Color="#FF375F"/>
          <SolidColorBrush x:Key="AccentSoft" Color="#33FF375F"/>
          <Color x:Key="AccentColor">#FF375F</Color>

          <!-- Text -->
          <SolidColorBrush x:Key="TextHigh" Color="#F5F5F7"/>
          <SolidColorBrush x:Key="TextMedium" Color="#C7C7CC"/>
          <SolidColorBrush x:Key="TextLow" Color="#8E8E93"/>

          <!-- Content surface -->
          <SolidColorBrush x:Key="ContentBg" Color="#0D0D14"/>
          <SolidColorBrush x:Key="ContentInk" Color="#F5F5F7"/>

          <!-- Translucent dark tint over the system vibrancy. -->
          <SolidColorBrush x:Key="WindowTint" Color="#73000000"/>

          <!-- Opaque-ish surface for floating popovers. -->
          <SolidColorBrush x:Key="OverlayBg" Color="#F525252A"/>
          <SolidColorBrush x:Key="OverlayBorder" Color="#3DFFFFFF"/>

          <!-- Liquid Glass platters, dark variant. Bumped to 25/35/45/35% white. -->
          <SolidColorBrush x:Key="PlatterBg" Color="#40FFFFFF"/>
          <SolidColorBrush x:Key="PlatterHoverBg" Color="#59FFFFFF"/>
          <SolidColorBrush x:Key="PlatterPressedBg" Color="#73FFFFFF"/>
          <SolidColorBrush x:Key="PlatterCheckedBg" Color="#59FFFFFF"/>
          <!-- Vertical edge gradient, dark variant. -->
          <LinearGradientBrush x:Key="PlatterBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#55FFFFFF" Offset="0"/>
            <GradientStop Color="#33000000" Offset="1"/>
          </LinearGradientBrush>
          <BoxShadows x:Key="ToolbarShadow">0 1 0 0 #20FFFFFF</BoxShadows>
          <SolidColorBrush x:Key="ToolbarSurface" Color="#00FFFFFF"/>
          <SolidColorBrush x:Key="PlatterIcon" Color="#F2FFFFFF"/>
          <SolidColorBrush x:Key="PlatterLabel" Color="#F5F5F7"/>
        </ResourceDictionary>

      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>

    <!-- ============ Global typography ============ -->
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Inter,Manrope,Segoe UI,-apple-system,sans-serif"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextHigh}"/>
    </Style>

    <!-- ============ Display headings (Manrope, light weight) ============ -->
    <Style Selector="TextBlock.display">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="Light"/>
      <Setter Property="FontSize" Value="34"/>
      <Setter Property="LetterSpacing" Value="-0.5"/>
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="LetterSpacing" Value="-0.3"/>
    </Style>

    <Style Selector="TextBlock.section">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="LetterSpacing" Value="1.2"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
    </Style>

    <Style Selector="TextBlock.meta">
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
    </Style>

  </Application.Styles>
</Application>
