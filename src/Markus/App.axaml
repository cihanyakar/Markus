<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Markus.App"
             xmlns:services="using:Markus.Services"
             RequestedThemeVariant="Default">

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="About Markus"
                      Command="{x:Static services:AppCommands.About}"/>
      <NativeMenuItem Header="Check for Updates…"
                      Command="{x:Static services:AppCommands.CheckForUpdates}"/>
      <NativeMenuItemSeparator/>
      <NativeMenuItem Header="Preferences…" Gesture="Cmd+,"
                      Command="{x:Static services:AppCommands.Preferences}"/>
      <NativeMenuItemSeparator/>
      <NativeMenuItem Header="Quit Markus" Gesture="Cmd+Q"
                      Command="{x:Static services:AppCommands.Quit}"/>
    </NativeMenu>
  </NativeMenu.Menu>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>

        <!-- ============ Light ============ -->
        <ResourceDictionary x:Key="Light">
          <!-- Atmosphere -->
          <SolidColorBrush x:Key="AppBackground" Color="#F6F6FA"/>
          <Color x:Key="MeshAColor">#E8B4A8</Color>
          <Color x:Key="MeshBColor">#B0BFEF</Color>
          <Color x:Key="MeshCColor">#A8DDD4</Color>

          <!-- Glass -->
          <SolidColorBrush x:Key="GlassBg" Color="#C0FFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#18000000"/>
          <SolidColorBrush x:Key="GlassDivider" Color="#0C000000"/>
          <SolidColorBrush x:Key="GlassHover" Color="#18000000"/>
          <SolidColorBrush x:Key="GlassPressed" Color="#28000000"/>

          <!-- Accent -->
          <SolidColorBrush x:Key="Accent" Color="{DynamicResource SystemAccentColor}"/>
          <SolidColorBrush x:Key="AccentSoft" Color="{DynamicResource SystemAccentColor}" Opacity="0.14"/>
          <DynamicResource x:Key="AccentColor" ResourceKey="SystemAccentColor"/>

          <!-- Text -->
          <SolidColorBrush x:Key="TextHigh" Color="#1A1A1F"/>
          <SolidColorBrush x:Key="TextMedium" Color="#3C3C44"/>
          <SolidColorBrush x:Key="TextLow" Color="#6E6E7A"/>

          <!-- Content surface -->
          <SolidColorBrush x:Key="ContentBg" Color="#88FFFFFF"/>
          <SolidColorBrush x:Key="ContentInk" Color="#1A1A1F"/>

          <!-- Translucent tint over the system vibrancy so chrome reads as
               frosted glass, not as bare blur. -->
          <SolidColorBrush x:Key="WindowTint" Color="#66FFFFFF"/>

          <!-- Opaque-ish surface for floating popovers (search overlay, etc.). -->
          <SolidColorBrush x:Key="OverlayBg" Color="#F5F6F8F9"/>
          <SolidColorBrush x:Key="OverlayBorder" Color="#22000000"/>

          <!-- Liquid Glass platters -->
          <SolidColorBrush x:Key="PlatterBg" Color="#5CFFFFFF"/>
          <SolidColorBrush x:Key="PlatterHoverBg" Color="#80FFFFFF"/>
          <SolidColorBrush x:Key="PlatterPressedBg" Color="#A6FFFFFF"/>
          <SolidColorBrush x:Key="PlatterCheckedBg" Color="#80FFFFFF"/>
          <LinearGradientBrush x:Key="PlatterBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#88FFFFFF" Offset="0"/>
            <GradientStop Color="#0C000000" Offset="1"/>
          </LinearGradientBrush>
          <BoxShadows x:Key="ToolbarShadow">0 1 2 0 #0A000000</BoxShadows>
          <SolidColorBrush x:Key="ToolbarSurface" Color="#00FFFFFF"/>
          <SolidColorBrush x:Key="PlatterIcon" Color="#8A000000"/>
          <SolidColorBrush x:Key="PlatterLabel" Color="#1A1A1F"/>
        </ResourceDictionary>

        <!-- ============ Dark ============ -->
        <ResourceDictionary x:Key="Dark">
          <!-- Atmosphere -->
          <SolidColorBrush x:Key="AppBackground" Color="#0A0A12"/>
          <Color x:Key="MeshAColor">#D94070</Color>
          <Color x:Key="MeshBColor">#4840C8</Color>
          <Color x:Key="MeshCColor">#0EA5BB</Color>

          <!-- Glass -->
          <SolidColorBrush x:Key="GlassBg" Color="#18FFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#22FFFFFF"/>
          <SolidColorBrush x:Key="GlassDivider" Color="#14FFFFFF"/>
          <SolidColorBrush x:Key="GlassHover" Color="#22FFFFFF"/>
          <SolidColorBrush x:Key="GlassPressed" Color="#33FFFFFF"/>

          <SolidColorBrush x:Key="Accent" Color="{DynamicResource SystemAccentColor}"/>
          <SolidColorBrush x:Key="AccentSoft" Color="{DynamicResource SystemAccentColor}" Opacity="0.18"/>
          <DynamicResource x:Key="AccentColor" ResourceKey="SystemAccentColor"/>

          <!-- Text -->
          <SolidColorBrush x:Key="TextHigh" Color="#F0F0F4"/>
          <SolidColorBrush x:Key="TextMedium" Color="#A8A8B4"/>
          <SolidColorBrush x:Key="TextLow" Color="#70707E"/>

          <!-- Content surface -->
          <SolidColorBrush x:Key="ContentBg" Color="#0E0E18"/>
          <SolidColorBrush x:Key="ContentInk" Color="#F0F0F4"/>

          <!-- Translucent dark tint over the system vibrancy. -->
          <SolidColorBrush x:Key="WindowTint" Color="#80000000"/>

          <!-- Opaque-ish surface for floating popovers. -->
          <SolidColorBrush x:Key="OverlayBg" Color="#F5202028"/>
          <SolidColorBrush x:Key="OverlayBorder" Color="#2AFFFFFF"/>

          <!-- Liquid Glass platters, dark variant. -->
          <SolidColorBrush x:Key="PlatterBg" Color="#1CFFFFFF"/>
          <SolidColorBrush x:Key="PlatterHoverBg" Color="#2AFFFFFF"/>
          <SolidColorBrush x:Key="PlatterPressedBg" Color="#3DFFFFFF"/>
          <SolidColorBrush x:Key="PlatterCheckedBg" Color="#2AFFFFFF"/>
          <LinearGradientBrush x:Key="PlatterBorderBrush" StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#40FFFFFF" Offset="0"/>
            <GradientStop Color="#18000000" Offset="1"/>
          </LinearGradientBrush>
          <BoxShadows x:Key="ToolbarShadow">0 1 2 0 #14FFFFFF</BoxShadows>
          <SolidColorBrush x:Key="ToolbarSurface" Color="#00FFFFFF"/>
          <SolidColorBrush x:Key="PlatterIcon" Color="#C2FFFFFF"/>
          <SolidColorBrush x:Key="PlatterLabel" Color="#F0F0F4"/>
        </ResourceDictionary>

      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>

    <!-- ============ Global typography ============ -->
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Inter,Manrope,Segoe UI,-apple-system,sans-serif"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextHigh}"/>
    </Style>

    <!-- ============ Display headings (Manrope, light weight) ============ -->
    <Style Selector="TextBlock.display">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="Light"/>
      <Setter Property="FontSize" Value="34"/>
      <Setter Property="LetterSpacing" Value="-0.5"/>
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="LetterSpacing" Value="-0.3"/>
    </Style>

    <Style Selector="TextBlock.section">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="LetterSpacing" Value="1.2"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
    </Style>

    <Style Selector="TextBlock.meta">
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
    </Style>

  </Application.Styles>
</Application>
