<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Markus.ViewModels"
             xmlns:models="using:Markus.Models"
             xmlns:views="using:Markus.Views"
             mc:Ignorable="d"
             x:Class="Markus.Views.OutlinePanel"
             x:DataType="vm:MainWindowViewModel">

  <UserControl.Styles>
    <Style Selector="Button.outlineTool">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Padding" Value="7"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14"/>
        </Transitions>
      </Setter>
    </Style>

    <!-- Stretch the outline rows across the panel so the click target spans
         the whole sidebar width, not just the text. -->
    <Style Selector="TreeView.outline TreeViewItem">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Button.outlineTool:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
    <Style Selector="Button.outlineTool PathIcon">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMedium}"/>
    </Style>
    <Style Selector="TextBox.outlineFilter">
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*" ClipToBounds="True">

    <!-- Title -->
    <StackPanel Grid.Row="0" Margin="16,14,16,8" Spacing="2">
      <TextBlock Classes="section" Text="ON THIS PAGE"/>
      <TextBlock Classes="h1" Text="Outline"/>
    </StackPanel>

    <!-- Toolbar: expand-all / collapse-all / quick search -->
    <Grid Grid.Row="1"
          Margin="12,0,12,8"
          ColumnDefinitions="Auto,Auto,*">
      <Button Grid.Column="0"
              Classes="outlineTool"
              Command="{Binding ExpandOutlineCommand}"
              ToolTip.Tip="Expand all">
        <PathIcon Data="{x:Static views:IconData.UnfoldMore}"/>
      </Button>
      <Button Grid.Column="1"
              Classes="outlineTool"
              Margin="2,0,8,0"
              Command="{Binding CollapseOutlineCommand}"
              ToolTip.Tip="Collapse all">
        <PathIcon Data="{x:Static views:IconData.UnfoldLess}"/>
      </Button>
      <TextBox Grid.Column="2"
               Classes="outlineFilter"
               PlaceholderText="Filter…"
               Text="{Binding OutlineFilter}"/>
    </Grid>

    <!-- Tree -->
    <TreeView Grid.Row="2"
              Name="OutlineTree"
              Classes="outline"
              ItemsSource="{Binding OutlineNodes}"
              Background="Transparent"
              BorderThickness="0"
              Padding="8,4,8,12"
              HorizontalAlignment="Stretch"
              DragDrop.AllowDrop="True"
              SelectionChanged="OutlineTree_SelectionChanged">
      <TreeView.Styles>
        <Style Selector="TreeViewItem" x:DataType="models:OutlineNode">
          <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
          <Setter Property="IsVisible" Value="{Binding IsVisible}"/>
        </Style>
      </TreeView.Styles>
      <TreeView.ItemTemplate>
        <TreeDataTemplate ItemsSource="{Binding Children}"
                          DataType="{x:Type models:OutlineNode}">
          <TextBlock Text="{Binding Text}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center"/>
        </TreeDataTemplate>
      </TreeView.ItemTemplate>
    </TreeView>

    <!-- Drag ghost overlay. Sits on top of every row, never intercepts
         pointer events. Its Canvas.Left/Top are mutated from code-behind to
         track the cursor while a heading is being dragged. -->
    <Canvas Grid.RowSpan="3"
            Name="DragOverlay"
            IsHitTestVisible="False"
            ZIndex="100">
      <!-- Drop-target indicator: three pre-styled Borders, only one of
           which is shown for a given drop. Pre-bound DynamicResources
           avoid expensive (or failure-prone) FindResource calls during
           each pointer-moved tick. -->
      <Border Name="DropBefore"
              IsVisible="False"
              Background="{DynamicResource Accent}"
              Height="2"
              CornerRadius="1"
              IsHitTestVisible="False"/>
      <Border Name="DropAfter"
              IsVisible="False"
              Background="{DynamicResource Accent}"
              Height="2"
              CornerRadius="1"
              IsHitTestVisible="False"/>
      <Border Name="DropInside"
              IsVisible="False"
              Background="{DynamicResource AccentSoft}"
              BorderBrush="{DynamicResource Accent}"
              BorderThickness="1"
              CornerRadius="4"
              IsHitTestVisible="False"/>
      <Border Name="DragGhost"
              IsVisible="False"
              Background="{DynamicResource AccentSoft}"
              BorderBrush="{DynamicResource Accent}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10,5"
              Opacity="0.92"
              BoxShadow="0 2 8 0 #28000000">
        <TextBlock Name="DragGhostText"
                   FontSize="12"
                   FontWeight="Medium"
                   Foreground="{DynamicResource TextHigh}"/>
      </Border>
    </Canvas>
  </Grid>
</UserControl>
