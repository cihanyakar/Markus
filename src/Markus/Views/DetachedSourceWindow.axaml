<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Markus.ViewModels"
        xmlns:views="using:Markus.Views"
        x:Class="Markus.Views.DetachedSourceWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="640" Height="720"
        MinWidth="420" MinHeight="320"
        Title="{Binding DocumentTitle, StringFormat='{}{0} — Source'}"
        Icon="/Assets/markus.png"
        Background="{DynamicResource AppBackground}">

  <Window.Styles>
    <Style Selector="Border.glass">
      <Setter Property="Background" Value="{DynamicResource GlassBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource GlassBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.statusbar">
      <Setter Property="BorderThickness" Value="0,1,0,0"/>
      <Setter Property="Padding" Value="18,7"/>
    </Style>
    <Style Selector="Border.titlestrip">
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="18,10"/>
    </Style>
    <Style Selector="TextBox.source">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="28,24"/>
      <Setter Property="AcceptsReturn" Value="True"/>
      <Setter Property="AcceptsTab" Value="True"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{DynamicResource ContentInk}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="TextBox.source /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </Window.Styles>

  <Panel>
    <Panel ZIndex="-1">
      <Rectangle IsHitTestVisible="False" Opacity="0.7">
        <Rectangle.Fill>
          <RadialGradientBrush Center="14%,18%" RadiusX="0.6" RadiusY="0.65">
            <GradientStop Color="{DynamicResource MeshAColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle IsHitTestVisible="False" Opacity="0.6">
        <Rectangle.Fill>
          <RadialGradientBrush Center="88%,84%" RadiusX="0.55" RadiusY="0.6">
            <GradientStop Color="{DynamicResource MeshBColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
    </Panel>

    <Grid RowDefinitions="Auto,*,Auto">
      <Border Grid.Row="0" Classes="glass titlestrip">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="section" Text="SOURCE"/>
          <TextBlock Foreground="{DynamicResource TextMedium}"
                     FontSize="12"
                     VerticalAlignment="Center"
                     Text="{Binding DocumentTitle}"
                     TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Border>

      <views:SourceEditor Grid.Row="1"
                          MonoFontFamily="{Binding MonoFontFamily}"
                          Text="{Binding SourceText, Mode=TwoWay}"/>

      <Border Grid.Row="2" Classes="glass statusbar">
        <TextBlock Classes="meta" Text="{Binding StatusText}"/>
      </Border>
    </Grid>
  </Panel>

</Window>
