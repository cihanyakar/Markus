<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Markus.ViewModels"
             xmlns:views="using:Markus.Views"
             mc:Ignorable="d"
             x:Class="Markus.Views.WelcomeView"
             x:DataType="vm:MainWindowViewModel">

  <UserControl.Styles>
    <Style Selector="Button.welcomeAction">
      <Setter Property="Background" Value="{DynamicResource GlassBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource GlassBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="20,16"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="MinWidth" Value="260"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.welcomeAction:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
    <Style Selector="Button.recentItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.14"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.recentItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <Grid Margin="56,48,56,48" RowDefinitions="Auto,Auto,Auto,Auto,*">

      <!-- Brand -->
      <StackPanel Grid.Row="0" Spacing="6">
        <TextBlock Text="MARKUS"
                   FontFamily="Manrope,Inter,sans-serif"
                   FontSize="11"
                   FontWeight="Medium"
                   LetterSpacing="1.6"
                   Foreground="{DynamicResource TextLow}"/>
        <TextBlock Classes="display"
                   Text="A focused Markdown editor."/>
        <TextBlock FontFamily="Inter,sans-serif"
                   FontSize="14"
                   Foreground="{DynamicResource TextMedium}"
                   Text="Write, preview, repeat."/>
      </StackPanel>

      <!-- Primary actions -->
      <StackPanel Grid.Row="1"
                  Margin="0,36,0,0"
                  Orientation="Horizontal"
                  Spacing="14">
        <Button Classes="welcomeAction" Command="{Binding OpenFileCommand}">
          <StackPanel Orientation="Horizontal" Spacing="14">
            <PathIcon Data="{x:Static views:IconData.FolderOpen}" Width="22" Height="22"/>
            <StackPanel Spacing="2">
              <TextBlock Text="Open file…"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextHigh}"/>
              <TextBlock Text="Pick a .md / .markdown document"
                         FontSize="11"
                         Foreground="{DynamicResource TextLow}"/>
            </StackPanel>
          </StackPanel>
        </Button>
        <Button Classes="welcomeAction" Command="{Binding NewScratchCommand}">
          <StackPanel Orientation="Horizontal" Spacing="14">
            <PathIcon Data="{x:Static views:IconData.Refresh}" Width="22" Height="22"/>
            <StackPanel Spacing="2">
              <TextBlock Text="New scratch"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextHigh}"/>
              <TextBlock Text="Start an unsaved buffer"
                         FontSize="11"
                         Foreground="{DynamicResource TextLow}"/>
            </StackPanel>
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Recent files header -->
      <TextBlock Grid.Row="2"
                 Margin="0,44,0,14"
                 Classes="section"
                 Text="RECENT"
                 IsVisible="{Binding HasRecentFiles}"/>

      <!-- Recent files list -->
      <ItemsControl Grid.Row="3"
                    ItemsSource="{Binding Settings.RecentFiles}"
                    IsVisible="{Binding HasRecentFiles}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <Button Classes="recentItem"
                    Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).OpenRecentCommand}"
                    CommandParameter="{Binding}"
                    HorizontalAlignment="Stretch">
              <Grid ColumnDefinitions="Auto,*">
                <PathIcon Grid.Column="0"
                          Data="{x:Static views:IconData.Folder}"
                          Width="14" Height="14"
                          Margin="0,0,12,0"
                          Foreground="{DynamicResource TextMedium}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextHigh}"
                           FontSize="13"/>
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Cheat sheet card -->
      <Border Grid.Row="4"
              Margin="0,44,0,0"
              MaxWidth="640"
              HorizontalAlignment="Left"
              Background="{DynamicResource GlassBg}"
              BorderBrush="{DynamicResource GlassBorder}"
              BorderThickness="1"
              CornerRadius="14"
              Padding="22,18">
        <StackPanel Spacing="8">
          <TextBlock Classes="section" Text="QUICK SYNTAX"/>
          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto"
                ColumnSpacing="22" RowSpacing="6">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="# heading" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="**bold**" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="*italic*" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="`code`" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="- list" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="1. ordered" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="&gt; quote" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="---" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="[link](url)" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="![img](path)" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="| a | b |" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="```fenced" FontFamily="JetBrains Mono,Cascadia Code,monospace" FontSize="12" Foreground="{DynamicResource TextMedium}"/>
          </Grid>
        </StackPanel>
      </Border>

    </Grid>
  </ScrollViewer>
</UserControl>
