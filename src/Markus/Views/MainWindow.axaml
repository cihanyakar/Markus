<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Markus.ViewModels"
        xmlns:views="using:Markus.Views"
        xmlns:models="using:Markus.Models"
        xmlns:ae="using:AvaloniaEdit"
        mc:Ignorable="d"
        d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="Markus.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="720" MinHeight="480"
        Title="{Binding DisplayTitle, StringFormat='{}{0} — Markus'}"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        WindowDecorations="Full">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="File">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open…" Gesture="Cmd+O"
                            Command="{Binding OpenFileCommand}"/>
            <NativeMenuItem Header="Save" Gesture="Cmd+S"
                            Command="{Binding SaveCommand}"/>
            <NativeMenuItem Header="Open Recent">
              <NativeMenuItem.Menu>
                <NativeMenu/>
              </NativeMenuItem.Menu>
            </NativeMenuItem>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Reload" Gesture="Cmd+R"
                            Command="{Binding ReloadCommand}"/>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>

      <NativeMenuItem Header="Edit">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Undo" Gesture="Cmd+Z"/>
            <NativeMenuItem Header="Redo" Gesture="Cmd+Shift+Z"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Cut" Gesture="Cmd+X"/>
            <NativeMenuItem Header="Copy" Gesture="Cmd+C"/>
            <NativeMenuItem Header="Paste" Gesture="Cmd+V"/>
            <NativeMenuItem Header="Select All" Gesture="Cmd+A"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Find" Gesture="Cmd+F"
                            Command="{Binding FindCommand}"/>
            <NativeMenuItem Header="Find Next" Gesture="Cmd+G"
                            Command="{Binding FindNextCommand}"/>
            <NativeMenuItem Header="Find Previous" Gesture="Cmd+Shift+G"
                            Command="{Binding FindPreviousCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Format Tables" Gesture="Cmd+Shift+F"
                            Command="{Binding FormatTablesCommand}"/>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>

      <NativeMenuItem Header="View">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Source" Gesture="Cmd+1"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:ViewMode.Source}"/>
            <NativeMenuItem Header="Preview" Gesture="Cmd+2"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:ViewMode.Preview}"/>
            <NativeMenuItem Header="Split Vertical" Gesture="Cmd+3"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:ViewMode.SplitVertical}"/>
            <NativeMenuItem Header="Split Horizontal" Gesture="Cmd+4"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:ViewMode.SplitHorizontal}"/>
            <NativeMenuItem Header="Detached" Gesture="Cmd+5"
                            Command="{Binding SetViewModeCommand}"
                            CommandParameter="{x:Static models:ViewMode.Detached}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Toggle Outline" Gesture="Cmd+Alt+B"
                            Command="{Binding ToggleOutlineCommand}"/>
            <NativeMenuItem Header="Sync Scroll" Gesture="Cmd+Shift+L"
                            ToggleType="CheckBox"
                            IsChecked="{Binding IsScrollLocked}"
                            Command="{Binding ToggleScrollLockCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Soft-Wrap Source"
                            ToggleType="CheckBox"
                            IsChecked="{Binding IsSourceSoftWrap}"
                            Command="{Binding ToggleSourceSoftWrapCommand}"/>
            <NativeMenuItem Header="Soft-Wrap Preview"
                            ToggleType="CheckBox"
                            IsChecked="{Binding IsPreviewSoftWrap}"
                            Command="{Binding TogglePreviewSoftWrapCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Focus Mode" Gesture="Cmd+Shift+M"
                            ToggleType="CheckBox"
                            IsChecked="{Binding IsFocusMode}"
                            Command="{Binding ToggleFocusModeCommand}"/>
            <NativeMenuItem Header="Typewriter Scrolling"
                            ToggleType="CheckBox"
                            IsChecked="{Binding IsTypewriterMode}"
                            Command="{Binding ToggleTypewriterModeCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Appearance">
              <NativeMenuItem.Menu>
                <NativeMenu>
                  <NativeMenuItem Header="System"
                                  Command="{Binding SetThemeModeCommand}"
                                  CommandParameter="System"/>
                  <NativeMenuItem Header="Light"
                                  Command="{Binding SetThemeModeCommand}"
                                  CommandParameter="Light"/>
                  <NativeMenuItem Header="Dark"
                                  Command="{Binding SetThemeModeCommand}"
                                  CommandParameter="Dark"/>
                </NativeMenu>
              </NativeMenuItem.Menu>
            </NativeMenuItem>
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>

  <Window.Styles>
    <!-- ============ Flat macOS-native toolbar controls ============ -->
    <!-- No persistent platter: a subtle rounded highlight appears only on
         hover/press, the way native toolbar buttons behave. -->
    <Style Selector="Button.tool, ToggleButton.tool">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="7,3"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="MinHeight" Value="22"/>
      <Setter Property="Foreground" Value="{DynamicResource PlatterLabel}"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
    <Style Selector="ToggleButton.tool:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
    <Style Selector="Button.tool:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassPressed}"/>
    </Style>
    <Style Selector="ToggleButton.tool:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
    <Style Selector="Button.tool PathIcon, ToggleButton.tool PathIcon">
      <Setter Property="Width" Value="13"/>
      <Setter Property="Height" Value="13"/>
      <Setter Property="Foreground" Value="{DynamicResource PlatterIcon}"/>
    </Style>
    <Style Selector="ToggleButton.tool:checked PathIcon">
      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="Button.tool TextBlock, ToggleButton.tool TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="{DynamicResource PlatterLabel}"/>
    </Style>

    <!-- Glass panel base -->
    <Style Selector="Border.glass">
      <Setter Property="Background" Value="{DynamicResource GlassBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource GlassBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Toolbar -->
    <Style Selector="Border.toolbar">
      <Setter Property="Background" Value="{DynamicResource ToolbarSurface}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,3"/>
      <Setter Property="BoxShadow" Value="{DynamicResource ToolbarShadow}"/>
    </Style>
    <Style Selector="Border.statusbar">
      <Setter Property="BorderThickness" Value="0,1,0,0"/>
      <Setter Property="Padding" Value="10,3"/>
    </Style>
    <Style Selector="Border.sidebar">
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <!-- Source editor: transparent so atmosphere shows through -->
    <Style Selector="TextBox.source">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="32,28"/>
      <Setter Property="AcceptsReturn" Value="True"/>
      <Setter Property="AcceptsTab" Value="True"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{DynamicResource ContentInk}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="TextBox.source /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ============ Segmented view-mode control ============ -->
    <!-- A grouped pill track holding RadioButton segments; the active segment
         lifts to a raised pill with an accent label, like a native segmented
         control. -->
    <Style Selector="Border.segmented">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="Padding" Value="2"/>
    </Style>
    <Style Selector="RadioButton.segment">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource PlatterLabel}"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="Padding" Value="9,3"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Name="seg"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="RadioButton.segment:pointerover /template/ Border#seg">
      <Setter Property="Background" Value="{DynamicResource GlassHover}"/>
    </Style>
    <Style Selector="RadioButton.segment:checked /template/ Border#seg">
      <Setter Property="Background" Value="{DynamicResource PlatterPressedBg}"/>
    </Style>
    <Style Selector="RadioButton.segment:checked">
      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="RadioButton.segment PathIcon">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="Foreground" Value="{DynamicResource PlatterIcon}"/>
    </Style>
    <Style Selector="RadioButton.segment:checked PathIcon">
      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- GridSplitter slim hairline -->
    <Style Selector="GridSplitter.hairline">
      <Setter Property="Background" Value="{DynamicResource GlassDivider}"/>
    </Style>
  </Window.Styles>

  <Panel>

    <!-- Translucent tint over the system NSVisualEffectView so chrome
         reads as frosted glass, not as bare desktop blur. -->
    <Rectangle IsHitTestVisible="False" Fill="{DynamicResource WindowTint}"/>

    <!-- ============ Atmosphere: subtle mesh over system vibrancy ============ -->
    <Panel ZIndex="-1">
      <Rectangle IsHitTestVisible="False" Opacity="0.18">
        <Rectangle.Fill>
          <RadialGradientBrush Center="14%,8%" GradientOrigin="14%,8%"
                               RadiusX="0.6" RadiusY="0.65">
            <GradientStop Color="{DynamicResource MeshAColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle IsHitTestVisible="False" Opacity="0.15">
        <Rectangle.Fill>
          <RadialGradientBrush Center="88%,88%" GradientOrigin="88%,88%"
                               RadiusX="0.65" RadiusY="0.7">
            <GradientStop Color="{DynamicResource MeshBColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle IsHitTestVisible="False" Opacity="0.12">
        <Rectangle.Fill>
          <RadialGradientBrush Center="80%,14%" GradientOrigin="80%,14%"
                               RadiusX="0.45" RadiusY="0.5">
            <GradientStop Color="{DynamicResource MeshCColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
    </Panel>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

      <!-- ============ Toolbar (glass, also serves as draggable title bar) ============ -->
      <Border Grid.Row="0" Classes="glass toolbar"
              Name="TitleBarRegion"
              IsVisible="{Binding !IsFocusMode}"
              PointerPressed="OnTitleBarPointerPressed">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Leading: traffic-light reservation + primary actions -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Border Name="WindowControlsInset" Width="0"/>
            <Button Classes="tool" Click="Open_Click">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{x:Static views:IconData.Folder}"/>
                <TextBlock Text="Open" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="tool" Command="{Binding SaveCommand}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{x:Static views:IconData.ContentSave}"/>
                <TextBlock Text="Save" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="tool" Command="{Binding ReloadCommand}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{x:Static views:IconData.Refresh}"/>
                <TextBlock Text="Reload" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Trailing: outline / view / settings -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <ToggleButton Classes="tool" IsChecked="{Binding IsScrollLocked}"
                          ToolTip.Tip="Sync scroll source ↔ preview (Scroll Lock / ⌘⇧L)">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{x:Static views:IconData.Lock}"/>
                <TextBlock Text="Sync" VerticalAlignment="Center"/>
              </StackPanel>
            </ToggleButton>
            <ToggleButton Classes="tool" IsChecked="{Binding IsOutlineVisible}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{x:Static views:IconData.Sidebar}"/>
                <TextBlock Text="Outline" VerticalAlignment="Center"/>
              </StackPanel>
            </ToggleButton>

            <!-- View mode: (Source | Preview) + (Split V | Split H) segments -->
            <Border Classes="segmented" Margin="6,0,0,0">
              <StackPanel Orientation="Horizontal" Spacing="2">
                <RadioButton Classes="segment" GroupName="viewmode"
                             Content="Source"
                             ToolTip.Tip="Source only (⌘1)"
                             IsChecked="{Binding IsSourceOnly, Mode=OneWay}"
                             Command="{Binding SetViewModeCommand}"
                             CommandParameter="{x:Static models:ViewMode.Source}"/>
                <RadioButton Classes="segment" GroupName="viewmode"
                             Content="Preview"
                             ToolTip.Tip="Preview only (⌘2)"
                             IsChecked="{Binding IsPreviewOnly, Mode=OneWay}"
                             Command="{Binding SetViewModeCommand}"
                             CommandParameter="{x:Static models:ViewMode.Preview}"/>
              </StackPanel>
            </Border>
            <Border Classes="segmented" Margin="4,0,0,0">
              <StackPanel Orientation="Horizontal" Spacing="2">
                <RadioButton Classes="segment" GroupName="viewmode"
                             ToolTip.Tip="Split vertical (⌘3)"
                             IsChecked="{Binding IsSplitVerticalActive, Mode=OneWay}"
                             Command="{Binding SetViewModeCommand}"
                             CommandParameter="{x:Static models:ViewMode.SplitVertical}">
                  <PathIcon Data="{x:Static views:IconData.SplitVertical}"/>
                </RadioButton>
                <RadioButton Classes="segment" GroupName="viewmode"
                             ToolTip.Tip="Split horizontal (⌘4)"
                             IsChecked="{Binding IsSplitHorizontalActive, Mode=OneWay}"
                             Command="{Binding SetViewModeCommand}"
                             CommandParameter="{x:Static models:ViewMode.SplitHorizontal}">
                  <PathIcon Data="{x:Static views:IconData.SplitHorizontal}"/>
                </RadioButton>
              </StackPanel>
            </Border>
            <Border Classes="segmented" Margin="4,0,0,0">
              <RadioButton Classes="segment" GroupName="viewmode"
                           ToolTip.Tip="Detached preview (⌘5)"
                           IsChecked="{Binding IsDetachedActive, Mode=OneWay}"
                           Command="{Binding SetViewModeCommand}"
                           CommandParameter="{x:Static models:ViewMode.Detached}">
                <PathIcon Data="{x:Static views:IconData.OpenInNew}"/>
              </RadioButton>
            </Border>

            <Button Classes="tool" Margin="6,0,0,0" Click="Settings_Click">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <PathIcon Data="{x:Static views:IconData.Settings}"/>
                <TextBlock Text="Settings" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

        </Grid>
      </Border>

      <!-- Update banner: shown only when a newer release was found. -->
      <Border Grid.Row="1"
              IsVisible="{Binding Update.IsUpdateAvailable, FallbackValue=False}"
              Background="{DynamicResource AccentSoft}"
              BorderBrush="{DynamicResource GlassBorder}"
              BorderThickness="0,0,0,1"
              Padding="16,8">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Column="0"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextHigh}"
                     Text="{Binding Update.AvailableVersion, StringFormat='A new version of Markus ({0}) is available'}"/>
          <Button Grid.Column="1" Margin="8,0,0,0" Content="Download"
                  Command="{Binding Update.DownloadCommand}"/>
          <Button Grid.Column="2" Margin="8,0,0,0" Content="Release notes"
                  Command="{Binding Update.ViewReleaseNotesCommand}"/>
          <Button Grid.Column="3" Margin="8,0,0,0" Content="Skip"
                  Command="{Binding Update.SkipCommand}"/>
          <Button Grid.Column="4" Margin="8,0,0,0" Content="Dismiss"
                  Command="{Binding Update.DismissCommand}"/>
        </Grid>
      </Border>

      <!-- ============ Content ============ -->
      <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- Outline on the LEFT (placement = Left). -->
        <Border Grid.Column="0"
                Classes="glass sidebar"
                Width="280"
                IsVisible="{Binding IsOutlineLeftVisible}">
          <views:OutlinePanel Name="OutlineLeft"
                              DataContext="{Binding}"/>
        </Border>
        <GridSplitter Grid.Column="1"
                      Classes="hairline"
                      ResizeDirection="Columns"
                      IsVisible="{Binding IsOutlineLeftVisible}"/>

        <Grid Grid.Column="2">

          <!-- Welcome screen — shown when no file open and no scratch started. -->
          <views:WelcomeView IsVisible="{Binding IsWelcomeVisible}"
                             ZIndex="5"/>

          <!-- Floating in-document search bar for the preview side. -->
          <views:SearchOverlay Name="PreviewSearch"
                                IsVisible="False"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,18,18,0"
                                ZIndex="10"/>

          <!-- Command palette (Cmd+K) -->
          <views:CommandPalette Name="CommandPalette"
                                 IsVisible="False"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Top"
                                 Margin="0,72,0,0"
                                 ZIndex="20"/>

          <!-- Source view: shown in Source-only mode and in Detached mode (the
               preview floats out to its own window in detached, source stays here). -->
          <views:MarkdownTextEditor Name="SourceOnlyEditor"
                                     IsVisible="{Binding IsSourceVisibleInMain}"
                                     FontFamily="{Binding MonoFontFamily}"
                                     BoundText="{Binding SourceText, Mode=TwoWay}"
                                     WordWrap="{Binding IsSourceSoftWrap}"
                                     TypewriterMode="{Binding IsTypewriterMode}"
                                     FontSize="{Binding EditorFontSize}"
                                     ShowLineNumbers="{Binding ShowLineNumbers}"
                                     HighlightActiveLine="{Binding HighlightCurrentLine}"
                                     AutoPairBrackets="{Binding AutoPairBrackets}"
                                     TabWidth="{Binding TabWidth}"/>

          <!-- Preview only -->
          <views:MarkdownPreviewControl Name="PreviewOnlyView"
                                         IsVisible="{Binding IsPreviewOnly}"
                                         Source="{Binding SourceText}"
                                         FullWidth="{Binding PreviewFullWidth}"/>

          <!-- Split vertical -->
          <Grid ColumnDefinitions="*,4,*" IsVisible="{Binding IsSplitVerticalActive}">
            <views:MarkdownTextEditor Grid.Column="0"
                                       FontFamily="{Binding MonoFontFamily}"
                                       BoundText="{Binding SourceText, Mode=TwoWay}"
                                     WordWrap="{Binding IsSourceSoftWrap}"
                                     TypewriterMode="{Binding IsTypewriterMode}"
                                     FontSize="{Binding EditorFontSize}"
                                     ShowLineNumbers="{Binding ShowLineNumbers}"
                                     HighlightActiveLine="{Binding HighlightCurrentLine}"
                                     AutoPairBrackets="{Binding AutoPairBrackets}"
                                     TabWidth="{Binding TabWidth}"/>
            <GridSplitter Grid.Column="1"
                          Classes="hairline"
                          ResizeDirection="Columns"/>
            <views:MarkdownPreviewControl Grid.Column="2"
                                           Name="SplitVPreviewView"
                                           Source="{Binding SourceText}"
                                         FullWidth="{Binding PreviewFullWidth}"/>
          </Grid>

          <!-- Split horizontal -->
          <Grid RowDefinitions="*,4,*" IsVisible="{Binding IsSplitHorizontalActive}">
            <views:MarkdownTextEditor Grid.Row="0"
                                       FontFamily="{Binding MonoFontFamily}"
                                       BoundText="{Binding SourceText, Mode=TwoWay}"
                                     WordWrap="{Binding IsSourceSoftWrap}"
                                     TypewriterMode="{Binding IsTypewriterMode}"
                                     FontSize="{Binding EditorFontSize}"
                                     ShowLineNumbers="{Binding ShowLineNumbers}"
                                     HighlightActiveLine="{Binding HighlightCurrentLine}"
                                     AutoPairBrackets="{Binding AutoPairBrackets}"
                                     TabWidth="{Binding TabWidth}"/>
            <GridSplitter Grid.Row="1"
                          Classes="hairline"
                          ResizeDirection="Rows"/>
            <views:MarkdownPreviewControl Grid.Row="2"
                                           Name="SplitHPreviewView"
                                           Source="{Binding SourceText}"
                                         FullWidth="{Binding PreviewFullWidth}"/>
          </Grid>


        </Grid>

        <GridSplitter Grid.Column="3"
                      Classes="hairline"
                      ResizeDirection="Columns"
                      IsVisible="{Binding IsOutlineRightVisible}"/>

        <!-- Outline on the RIGHT (placement = Right). -->
        <Border Grid.Column="4"
                Classes="glass sidebar"
                Width="280"
                IsVisible="{Binding IsOutlineRightVisible}">
          <views:OutlinePanel Name="OutlineRight"
                              DataContext="{Binding}"/>
        </Border>

      </Grid>

      <!-- ============ Status bar (glass) ============ -->
      <Border Grid.Row="3" Classes="glass statusbar" IsVisible="{Binding !IsFocusMode}">
        <DockPanel LastChildFill="False">
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="10">
            <TextBlock Classes="section" Text="STATUS"/>
            <TextBlock Foreground="{DynamicResource TextMedium}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText}"/>
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="14">
            <TextBlock Foreground="{DynamicResource TextMedium}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Text="{Binding CaretPosition}"/>
            <TextBlock Foreground="{DynamicResource Accent}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Text="{Binding SelectionStats}"
                       IsVisible="{Binding HasSelection}"/>
            <TextBlock Foreground="{DynamicResource TextLow}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Text="{Binding DocumentStats}"
                       IsVisible="{Binding !HasSelection}"/>
            <TextBlock Classes="section" Text="VIEW"/>
            <TextBlock Foreground="{DynamicResource TextMedium}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Text="{Binding CurrentViewMode}"/>
          </StackPanel>
        </DockPanel>
      </Border>

    </Grid>
  </Panel>
</Window>
