<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Markus.ViewModels"
        xmlns:views="using:Markus.Views"
        mc:Ignorable="d"
        x:Class="Markus.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="{Binding SelectedCategory.Name}"
        Width="580" Height="720"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

  <!-- Photos.app palette, scoped to this window only so Markus's brand red
       elsewhere stays intact. Numbers picked from the reference screenshot
       (Photos Settings, macOS Tahoe, light + dark). -->
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="SettingsWindowBg" Color="#FCFCFD"/>
          <SolidColorBrush x:Key="SettingsDivider" Color="#0A000000"/>
          <SolidColorBrush x:Key="SettingsTitle" Color="#1D1D1F"/>
          <SolidColorBrush x:Key="SettingsLabel" Color="#1D1D1F"/>
          <SolidColorBrush x:Key="SettingsLabelMuted" Color="#5C5C66"/>
          <SolidColorBrush x:Key="SettingsHint" Color="#86868B"/>
          <!-- Photos.app selected tab: barely visible monochromatic gray box,
               no color change on icon or text. -->
          <SolidColorBrush x:Key="SettingsTabIcon" Color="#3C3C43"/>
          <SolidColorBrush x:Key="SettingsTabActiveBg" Color="#ECECEE"/>
          <SolidColorBrush x:Key="SettingsTabActiveBorder" Color="#D8D8DD"/>
          <SolidColorBrush x:Key="SettingsTabHoverBg" Color="#08000000"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="SettingsWindowBg" Color="#1E1E20"/>
          <SolidColorBrush x:Key="SettingsDivider" Color="#15FFFFFF"/>
          <SolidColorBrush x:Key="SettingsTitle" Color="#F5F5F7"/>
          <SolidColorBrush x:Key="SettingsLabel" Color="#F5F5F7"/>
          <SolidColorBrush x:Key="SettingsLabelMuted" Color="#B0B0BA"/>
          <SolidColorBrush x:Key="SettingsHint" Color="#98989D"/>
          <SolidColorBrush x:Key="SettingsTabIcon" Color="#C7C7CC"/>
          <SolidColorBrush x:Key="SettingsTabActiveBg" Color="#2F2F33"/>
          <SolidColorBrush x:Key="SettingsTabActiveBorder" Color="#3F3F44"/>
          <SolidColorBrush x:Key="SettingsTabHoverBg" Color="#12FFFFFF"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Window.Background>
    <DynamicResource ResourceKey="SettingsWindowBg"/>
  </Window.Background>

  <Window.Styles>
    <!-- ============ Title bar (28pt + traffic lights float at upper-left) ============ -->
    <Style Selector="TextBlock.windowTitle">
      <Setter Property="FontFamily" Value="-apple-system,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsTitle}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- ============ Tab strip (Photos.app style — monochromatic, subtle) ============ -->
    <Style Selector="ListBox.topTabs">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="ListBox.topTabs ListBoxItem">
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="3,0"/>
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="MinWidth" Value="76"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.topTabs ListBoxItem PathIcon">
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsTabIcon}"/>
    </Style>
    <Style Selector="ListBox.topTabs ListBoxItem TextBlock">
      <Setter Property="FontFamily" Value="-apple-system,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsLabel}"/>
      <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>
    <Style Selector="ListBox.topTabs ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SettingsTabHoverBg}"/>
    </Style>
    <!-- Selected: only background + faint border change; icon and text colors
         stay identical to the unselected state. -->
    <Style Selector="ListBox.topTabs ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SettingsTabActiveBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SettingsTabActiveBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ============ Form rows ============ -->
    <Style Selector="Grid.row">
      <Setter Property="Margin" Value="0,10"/>
    </Style>
    <Style Selector="TextBlock.rowLabel">
      <Setter Property="FontFamily" Value="-apple-system,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="Margin" Value="0,5,8,0"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsLabel}"/>
    </Style>
    <Style Selector="TextBlock.hint">
      <Setter Property="FontFamily" Value="-apple-system,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsHint}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="MaxWidth" Value="320"/>
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsLabel}"/>
    </Style>
    <Style Selector="RadioButton">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="{DynamicResource SettingsLabel}"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Border.divider">
      <Setter Property="BorderThickness" Value="0,1,0,0"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SettingsDivider}"/>
    </Style>
  </Window.Styles>

  <DockPanel>

    <!-- Title bar (28pt) — traffic lights float at upper-left, title centered. -->
    <StackPanel DockPanel.Dock="Top">
      <Border Height="28">
        <TextBlock Classes="windowTitle" Text="{Binding SelectedCategory.Name}"/>
      </Border>
      <!-- Tab strip: 6pt above, 18pt below (Photos measurement). -->
      <Border Padding="0,6,0,18">
        <ListBox Classes="topTabs"
                 ItemsSource="{x:Static vm:SettingsViewModel.Categories}"
                 SelectedItem="{Binding SelectedCategory}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SettingsCategoryItem">
              <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <PathIcon Data="{Binding Icon}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
      <Border Classes="divider"/>
    </StackPanel>

    <!-- Footer. -->
    <Border DockPanel.Dock="Bottom"
            Classes="divider"
            Padding="24,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Classes="hint"
                   VerticalAlignment="Center"
                   MaxWidth="9999"
                   Text="{Binding SettingsDirectory, StringFormat='Saved to {0}'}"
                   TextTrimming="CharacterEllipsis"/>
        <Button Grid.Column="1"
                Content="Restore defaults"
                Command="{Binding RestoreDefaultsCommand}"/>
      </Grid>
    </Border>

    <!-- Form body. Tight Photos-style padding. -->
    <ScrollViewer Padding="28,18,28,16">
      <Panel>

        <!-- ====== Appearance ====== -->
        <StackPanel IsVisible="{Binding IsAppearanceSelected}" Spacing="0">
          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Mode:" Classes="rowLabel"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <RadioButton Content="System"
                           GroupName="ThemeMode"
                           IsChecked="{Binding ThemeMode, Mode=TwoWay, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=System}"/>
              <RadioButton Content="Light"
                           GroupName="ThemeMode"
                           Margin="12,0,0,0"
                           IsChecked="{Binding ThemeMode, Mode=TwoWay, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Light}"/>
              <RadioButton Content="Dark"
                           GroupName="ThemeMode"
                           Margin="12,0,0,0"
                           IsChecked="{Binding ThemeMode, Mode=TwoWay, Converter={x:Static views:EqualsConverter.Instance}, ConverterParameter=Dark}"/>
            </StackPanel>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Preview theme:" Classes="rowLabel"/>
            <ComboBox Grid.Column="1"
                      MinWidth="220"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableThemes}"
                      SelectedValueBinding="{Binding Key}"
                      SelectedValue="{Binding Theme}"
                      DisplayMemberBinding="{Binding Display}"/>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Code theme:" Classes="rowLabel"/>
            <StackPanel Grid.Column="1" Spacing="6">
              <ComboBox MinWidth="220"
                        HorizontalAlignment="Left"
                        ItemsSource="{x:Static vm:SettingsViewModel.AvailableCodeThemes}"
                        SelectedValueBinding="{Binding Key}"
                        SelectedValue="{Binding CodeTheme}"
                        DisplayMemberBinding="{Binding Display}"/>
              <TextBlock Classes="hint" Text="Auto follows the app mode."/>
            </StackPanel>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Font size:" Classes="rowLabel"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
              <Slider Width="220"
                      Minimum="10" Maximum="28"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True"
                      Value="{Binding FontSize}"/>
              <TextBlock VerticalAlignment="Center"
                         Foreground="{DynamicResource SettingsLabelMuted}"
                         Text="{Binding FontSize, StringFormat='{}{0:0} pt'}"/>
            </StackPanel>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Code font:" Classes="rowLabel"/>
            <ComboBox Grid.Column="1"
                      MinWidth="220"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableMonoFonts}"
                      SelectedItem="{Binding MonoFont}"/>
          </Grid>
        </StackPanel>

        <!-- ====== View ====== -->
        <StackPanel IsVisible="{Binding IsViewSelected}" Spacing="0">
          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Default view:" Classes="rowLabel"/>
            <ComboBox Grid.Column="1"
                      MinWidth="220"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableViewModes}"
                      SelectedItem="{Binding DefaultViewMode}"/>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Outline:" Classes="rowLabel"/>
            <StackPanel Grid.Column="1" Spacing="6">
              <CheckBox Content="Show outline panel by default"
                        IsChecked="{Binding ShowOutline}"/>
              <ComboBox MinWidth="160"
                        HorizontalAlignment="Left"
                        ItemsSource="{x:Static vm:SettingsViewModel.AvailableOutlinePlacements}"
                        SelectedItem="{Binding OutlinePlacement}"/>
            </StackPanel>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Source:" Classes="rowLabel"/>
            <CheckBox Grid.Column="1"
                      Content="Wrap long lines in the source editor"
                      IsChecked="{Binding IsSourceSoftWrap}"/>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Preview:" Classes="rowLabel"/>
            <StackPanel Grid.Column="1" Spacing="6">
              <CheckBox Content="Wrap long lines in rendered code blocks"
                        IsChecked="{Binding IsPreviewSoftWrap}"/>
              <TextBlock Classes="hint"
                         Text="Default view applies the next time you open a document."/>
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- ====== General ====== -->
        <StackPanel IsVisible="{Binding IsGeneralSelected}" Spacing="0">
          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Renderer:" Classes="rowLabel"/>
            <StackPanel Grid.Column="1" Spacing="6">
              <ComboBox MinWidth="220"
                        HorizontalAlignment="Left"
                        ItemsSource="{x:Static vm:SettingsViewModel.AvailableRenderers}"
                        SelectedItem="{Binding Renderer}"/>
              <TextBlock Classes="hint"
                         Text="The Native renderer parses with Markdig and emits Avalonia controls."/>
            </StackPanel>
          </Grid>

          <Grid Classes="row" ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="Language:" Classes="rowLabel"/>
            <ComboBox Grid.Column="1"
                      MinWidth="220"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableLanguages}"
                      SelectedValueBinding="{Binding Code}"
                      SelectedValue="{Binding Language}"
                      DisplayMemberBinding="{Binding Display}"/>
          </Grid>
        </StackPanel>

      </Panel>
    </ScrollViewer>
  </DockPanel>
</Window>
