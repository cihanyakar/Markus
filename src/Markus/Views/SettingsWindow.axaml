<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Markus.ViewModels"
        mc:Ignorable="d"
        x:Class="Markus.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="760" Height="520"
        MinWidth="640" MinHeight="440"
        CanResize="True"
        ShowInTaskbar="False"
        Icon="/Assets/markus.png"
        WindowStartupLocation="CenterOwner">

  <Window.Styles>
    <Style Selector="ListBox.sidebar">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0,12"/>
    </Style>
    <Style Selector="ListBox.sidebar ListBoxItem">
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="Margin" Value="6,1"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="ListBox.sidebar ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
    </Style>
    <Style Selector="ListBox.sidebar ListBoxItem:selected TextBlock">
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
    <Style Selector="TextBlock.row-label">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"/>
    </Style>
    <Style Selector="TextBlock.hint">
      <Setter Property="Opacity" Value="0.65"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="Border.section">
      <Setter Property="Padding" Value="0,0,0,8"/>
    </Style>
  </Window.Styles>

  <DockPanel>

    <!-- ============ Footer (Restore defaults + Done) ============ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Classes="hint"
                   VerticalAlignment="Center"
                   Text="{Binding SettingsDirectory, StringFormat='Saved to {0}'}"
                   TextTrimming="CharacterEllipsis"/>
        <Button Grid.Column="1"
                Content="Restore defaults"
                Command="{Binding RestoreDefaultsCommand}"
                Margin="0,0,8,0"/>
        <Button Grid.Column="2"
                Content="Done"
                Classes="accent"
                Click="Done_Click"/>
      </Grid>
    </Border>

    <!-- ============ Sidebar + Content ============ -->
    <Grid ColumnDefinitions="220,*">

      <ListBox Grid.Column="0"
               Classes="sidebar"
               ItemsSource="{x:Static vm:SettingsViewModel.Categories}"
               SelectedItem="{Binding SelectedCategory}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:SettingsCategoryItem">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="{Binding Glyph}" FontSize="16"/>
              <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ScrollViewer Grid.Column="1" Padding="40,32">
        <StackPanel>

        <!-- ====== Appearance ====== -->
        <StackPanel IsVisible="{Binding IsAppearanceSelected}" Spacing="0">
          <TextBlock Classes="title" Text="Appearance"/>
          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="14">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="row-label" Text="Theme"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      MaxWidth="320"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableThemes}"
                      SelectedValueBinding="{Binding Key}"
                      SelectedValue="{Binding Theme}"
                      DisplayMemberBinding="{Binding Display}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="row-label" Text="Font size"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="12">
              <Slider Width="240"
                      Minimum="10" Maximum="28"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True"
                      Value="{Binding FontSize}"/>
              <TextBlock VerticalAlignment="Center"
                         Text="{Binding FontSize, StringFormat='{}{0:0} pt'}"/>
            </StackPanel>
          </Grid>
          <TextBlock Classes="hint"
                     Margin="0,18,0,0"
                     MaxWidth="380"
                     HorizontalAlignment="Left"
                     Text="Themes restyle the rendered preview. Bundled themes ship with the app; user themes can be dropped into the settings directory."/>
        </StackPanel>

        <!-- ====== View ====== -->
        <StackPanel IsVisible="{Binding IsViewSelected}" Spacing="0">
          <TextBlock Classes="title" Text="View"/>
          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="14">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="row-label" Text="Default view"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      MaxWidth="320"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableViewModes}"
                      SelectedItem="{Binding DefaultViewMode}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="row-label" Text="Outline"/>
            <CheckBox Grid.Row="1" Grid.Column="1"
                      Content="Show outline panel by default"
                      IsChecked="{Binding ShowOutline}"/>
          </Grid>
          <TextBlock Classes="hint"
                     Margin="0,18,0,0"
                     MaxWidth="380"
                     HorizontalAlignment="Left"
                     Text="Default view applies the next time you open a document. Detached mode shows source and preview in separate windows."/>
        </StackPanel>

        <!-- ====== General ====== -->
        <StackPanel IsVisible="{Binding IsGeneralSelected}" Spacing="0">
          <TextBlock Classes="title" Text="General"/>
          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="14">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="row-label" Text="Renderer"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      MaxWidth="320"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableRenderers}"
                      SelectedItem="{Binding Renderer}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="row-label" Text="Language"/>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      MaxWidth="320"
                      HorizontalAlignment="Left"
                      ItemsSource="{x:Static vm:SettingsViewModel.AvailableLanguages}"
                      SelectedValueBinding="{Binding Code}"
                      SelectedValue="{Binding Language}"
                      DisplayMemberBinding="{Binding Display}"/>
          </Grid>
          <TextBlock Classes="hint"
                     Margin="0,18,0,0"
                     MaxWidth="380"
                     HorizontalAlignment="Left"
                     Text="The Native renderer parses with Markdig and emits Avalonia controls. Placeholder renders source as plain text. Language other than English is wired but not yet translated."/>
        </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Grid>

  </DockPanel>
</Window>
