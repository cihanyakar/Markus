<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:services="using:Markus.Services"
        mc:Ignorable="d"
        x:Class="Markus.Views.AboutWindow"
        Title="About Markus"
        Width="440" Height="520"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur">

  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource OverlayBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource OverlayBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="Padding" Value="32,36,32,24"/>
    </Style>
    <Style Selector="TextBlock.display">
      <Setter Property="FontFamily" Value="Manrope,Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontWeight" Value="Light"/>
      <Setter Property="FontSize" Value="34"/>
      <Setter Property="LetterSpacing" Value="-0.5"/>
      <Setter Property="Foreground" Value="{DynamicResource TextHigh}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.version">
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.tagline">
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMedium}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBlock.copyright">
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource TextLow}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="Button.link">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
    </Style>
    <Style Selector="Button.link:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Window.Styles>

  <Panel>

    <!-- Atmosphere mesh, lighter than the main window. -->
    <Panel ZIndex="-1">
      <Rectangle IsHitTestVisible="False" Opacity="0.55">
        <Rectangle.Fill>
          <RadialGradientBrush Center="20%,14%" RadiusX="0.65" RadiusY="0.7">
            <GradientStop Color="{DynamicResource MeshAColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle IsHitTestVisible="False" Opacity="0.45">
        <Rectangle.Fill>
          <RadialGradientBrush Center="84%,86%" RadiusX="0.6" RadiusY="0.65">
            <GradientStop Color="{DynamicResource MeshBColor}" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
    </Panel>

    <Border Classes="card"
            Margin="22"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            PointerPressed="OnCardPointerPressed">
      <Grid RowDefinitions="*,Auto">

        <StackPanel Grid.Row="0"
                    Spacing="14"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch">

          <Image Name="AppIconImage"
                 Width="96" Height="96"
                 HorizontalAlignment="Center"
                 Stretch="Uniform"/>

          <StackPanel Spacing="2">
            <TextBlock Classes="display" Text="Markus"/>
            <TextBlock Classes="version"
                       Name="VersionLabel"
                       Text="dev"/>
          </StackPanel>

          <TextBlock Classes="tagline"
                     Margin="0,10,0,0"
                     Text="Native markdown viewer for macOS."/>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="4"
                      Margin="0,6,0,0">
            <Button Classes="link"
                    Content="GitHub"
                    Click="OnGithubClick"/>
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource TextLow}"
                       FontSize="12"
                       Text="·"/>
            <Button Classes="link"
                    Content="License"
                    Click="OnLicenseClick"/>
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource TextLow}"
                       FontSize="12"
                       Text="·"/>
            <Button Classes="link"
                    Content="Check for Updates"
                    Command="{x:Static services:AppCommands.CheckForUpdates}"/>
          </StackPanel>

          <TextBlock Classes="copyright"
                     Margin="0,8,0,0"
                     Text="© 2026 Cihan Yakar. MIT License."/>

        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
          <Button Grid.Column="1"
                  Content="Close"
                  MinWidth="84"
                  Click="OnCloseClick"
                  IsDefault="True"
                  IsCancel="True"/>
        </Grid>

      </Grid>
    </Border>

  </Panel>
</Window>
